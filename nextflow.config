// ─────────────────────────────────────────────────────────────────────────────
// nextflow.config — runtime settings for the COVID sequencing pipeline
// ─────────────────────────────────────────────────────────────────────────────

// Tell Nextflow to use the freyja-env conda environment for every process.
// This means all tools (freyja, minimap2, ivar, fastp, etc.) are available
// without manually activating the environment.
conda.enabled = true

process {
    // FREYJA_CONDA_ENV env var overrides this — set it before `nextflow run`
    // on any machine where the env isn't at the Mac's default path (e.g. the
    // AWS test instance uses ~/miniforge3/envs/freyja-env).
    conda = System.getenv('FREYJA_CONDA_ENV') ?: '/opt/anaconda3/envs/freyja-env'

    // How many samples to process in parallel. Each sample uses 4 threads
    // (params.threads) — size this to roughly (vCPU count / 4), leaving a
    // little headroom. 2 is right for a 10-core Mac or an 8-vCPU test
    // instance; scale up on bigger production hardware.
    maxForks = 2

    // If a process fails, retry once before giving up.
    errorStrategy = 'retry'
    maxRetries    = 1
}

// Store intermediate files outside the iCloud path to avoid symlink issues
// with spaces in "Mobile Documents". The cache still works for -resume.
//
// NF_WORK_DIR overrides this — set it before `nextflow run` on machines
// where /tmp isn't a large disk-backed filesystem. On the AWS test instance,
// /tmp turned out to be a 7.7GB RAM-backed tmpfs (100% full after 4 samples'
// intermediate files), while the actual 200GB EBS root volume sat almost
// empty — the pipeline died with "No space left on device" using the Mac
// default here unmodified. Point NF_WORK_DIR at the real disk instead.
workDir = System.getenv('NF_WORK_DIR') ?: '/tmp/nf-covid-work'

// Copy input files into work directory instead of symlinking.
// Required on the Mac because the project lives in an iCloud path with
// spaces — symlinks into an iCloud-synced tree cause issues. NOT needed
// (and wasteful — duplicates every intermediate file at every pipeline
// stage) on a plain Linux disk with no cloud sync, hence the override.
process.stageInMode = System.getenv('NF_STAGE_IN_MODE') ?: 'copy'
