// ─────────────────────────────────────────────────────────────────────────────
// nextflow.config — runtime settings for the COVID sequencing pipeline
// ─────────────────────────────────────────────────────────────────────────────

// Tell Nextflow to use the freyja-env conda environment for every process.
// This means all tools (freyja, minimap2, ivar, fastp, etc.) are available
// without manually activating the environment.
conda.enabled = true

process {
    conda = '/opt/anaconda3/envs/freyja-env'

    // How many samples to process in parallel.
    // Your Mac has 10 cores. Each sample uses 4 threads (params.threads),
    // so 2 samples in parallel = 8 cores used. Safe default.
    maxForks = 2

    // If a process fails, retry once before giving up.
    errorStrategy = 'retry'
    maxRetries    = 1
}

// Store intermediate files outside the iCloud path to avoid symlink issues
// with spaces in "Mobile Documents". The cache still works for -resume.
workDir = '/tmp/nf-covid-work'

// Copy input files into work directory instead of symlinking.
// Required because the project lives in an iCloud path with spaces.
process.stageInMode = 'copy'
