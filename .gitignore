# Raw sequencing data — large files, re-downloadable from SRA
data/raw/

# Per-sample pipeline intermediates — large, reproducible
data/results/*/trimmed/
data/results/*/aligned/
data/results/*/variants/

# Freyja internal staging files
data/results/_aggregate/
data/results/_times_metadata.csv
data/results/all_samples_aggregated_timed.tsv

# Stray SRA download folders (prefetch sometimes leaves these in project root)
SRR*/

# Per-sample freyja results and generated outputs — reproducible, keep out of git
data/results/

# Accession lists and metadata — drop into data/ folders at runtime
data/accessions/
data/metadata/

# Nextflow cache and logs
.nextflow/
.nextflow.log*
work/

# Nextflow binary (if downloaded locally)
nextflow

# macOS
.DS_Store

# CDC wastewater surveillance site code mapping — not public data
cdc_site_code.csv

# AWS test outputs — contain real site names via ANNOTATE_SITE_DATE, not public data
aws_test_results/

# SSH private keys — never commit
*.pem

# R session junk
.Rhistory

# Office lock files
~$*.docx

# Generated README duplicate (source of truth is README.md)
README.html
